# .gitignore
# Dependencies
node_modules/
.pnpm-store/
.yarn/

# Build output
.next/
out/
build/
dist/

# TypeScript
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.production
.env.development

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Next.js
.next/
.cache/

# Testing
coverage/

# Misc
*.pem
*.node

# Data files (keep structure but ignore actual data if any)
public/data/*.xlsx
!public/data/.gitkeepnode_modules/
.next/
.env
public/data/*.xlsx
